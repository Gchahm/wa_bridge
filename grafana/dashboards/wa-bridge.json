{
  "uid": "wa-bridge-overview",
  "title": "WA Bridge Overview",
  "tags": ["whatsapp"],
  "timezone": "browser",
  "editable": true,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Log volume by level",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({container=~\".*whatsapp.*\"} | json | level != \"\" [$__auto]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" },
            "fillOpacity": 80,
            "pointSize": 5
          },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warn" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "debug" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "title": "Errors over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({container=~\".*whatsapp.*\"} | json | level =~ \"error|warn\" [$__auto]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "pointSize": 5
          },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warn" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "title": "Messages received",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "count_over_time({container=~\".*whatsapp.*\"} | json | message = \"message saved\" [$__auto])",
          "legendFormat": "received",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          },
          "color": { "fixedColor": "green", "mode": "fixed" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 4,
      "title": "Messages sent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "count_over_time({container=~\".*whatsapp.*\"} | json | message = \"message sent\" [$__auto])",
          "legendFormat": "sent",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          },
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 5,
      "title": "Webhook failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "count_over_time({container=~\".*whatsapp.*\"} | json | message = \"webhook returned non-2xx status\" [$__auto])",
          "legendFormat": "non-2xx",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          },
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "title": "Media upload errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "count_over_time({container=~\".*whatsapp.*\"} | json | message =~ \"failed to (download|upload) media\" [$__auto])",
          "legendFormat": "media errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          },
          "color": { "fixedColor": "red", "mode": "fixed" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "title": "Recent errors",
      "type": "logs",
      "gridPos": { "h": 14, "w": 16, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{container=~\".*whatsapp.*\"} | json | level =~ \"error|warn\" | line_format \"{{.level}} [{{.component}}] {{.message}}{{if .error}} | {{.error}}{{end}}{{if .message_id}} | msg_id={{.message_id}}{{end}}{{if .chat_id}} | chat={{.chat_id}}{{end}}{{if .status_code}} | status={{.status_code}}{{end}}\"",
          "refId": "A",
          "maxLines": 100
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 8,
      "title": "Component breakdown",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum by (component) (count_over_time({container=~\".*whatsapp.*\"} | json | component != \"\" [$__auto]))",
          "legendFormat": "{{component}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["sum"]
        },
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "pie",
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39
}
